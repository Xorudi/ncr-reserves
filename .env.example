# ──────────────────────────────────────────────────────────────
# NCR RESERVES — Environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ──────────────────────────────────────────────────────────────

# Supabase project URL  (Dashboard → Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon/public key  (Dashboard → Project Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────
# When these vars are NOT set (e.g. during local development
# without a backend), the app runs in offline-only mode:
#   • All data is stored in localStorage + IndexedDB
#   • Cloud sync is silently disabled
#   • No errors are thrown
# ──────────────────────────────────────────────────────────────
